# ── NowSay 환경 설정 예시 ─────────────────────────
# 이 파일을 .env로 복사한 뒤 값을 수정하세요
# cp .env.example .env

# 관리자 계정
ADMIN_USER=admin
ADMIN_PASS=your-secure-password-here

# 세션 시크릿 (반드시 변경하세요)
SESSION_SECRET=change-me-to-random-string-in-production

# 서버 설정
PORT=3000
HOST=0.0.0.0

# DB 경로 (Docker 사용 시 볼륨 경로로 설정)
# DB_PATH=/app/data/nowsay.db
